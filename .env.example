# Path to your music library on the host machine
MUSIC_DIR=/path/to/your/music

# Soulseek credentials (slskd)
SLSKD_USERNAME=your-soulseek-username
SLSKD_PASSWORD=your-soulseek-password

# Navidrome credentials
# Set NAVIDROME_USER/NAVIDROME_PASS after completing first-run Navidrome setup
NAVIDROME_USER=admin
NAVIDROME_PASS=

# Optional: override internal Docker service URLs (defaults work for docker-compose)
# NAVIDROME_URL=http://navidrome:4533
# SLSKD_URL=http://slskd:5030
