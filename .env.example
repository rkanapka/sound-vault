# Path to your music library on the host machine
MUSIC_DIR=/path/to/your/music

# Soulseek credentials (slskd)
SLSKD_USERNAME=your-soulseek-username
SLSKD_PASSWORD=your-soulseek-password

# Navidrome credentials
# Set NAVIDROME_USER/NAVIDROME_PASS after completing first-run Navidrome setup
NAVIDROME_USER=admin
NAVIDROME_PASS=

# Sound Vault image tag. Defaults to "latest".
# Pin to a version (e.g. 1.2.3) for stability.
SOUNDVAULT_IMAGE_TAG=latest

# Host port for the Sound Vault web UI. Defaults to 8080.
# SOUNDVAULT_PORT=8080

# Directory for persistent service data (navidrome DB, slskd state).
# Defaults to ./data relative to the compose file.
# DATA_DIR=./data

# Internal Docker service URLs — only override for non-standard network setups
# NAVIDROME_URL=http://navidrome:4533
# SLSKD_URL=http://slskd:5030
